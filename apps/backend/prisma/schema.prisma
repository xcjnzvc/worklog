generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------------------------------
// 1. Enum 정의 (상태값들을 안전하게 관리)
// ------------------------------------------------------

enum Role {
  OWNER
  ADMIN
  USER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  ANNUAL // 연차
  HALF // 반차
}

// ------------------------------------------------------
// 2. 모델 정의
// ------------------------------------------------------

// 회사
model Company {
  id            String   @id @default(uuid())
  name          String   @unique
  workType      String   @default("FIXED")
  workStartTime String   @default("09:00")
  coreTimeStart String?
  coreTimeEnd   String?
  lunchMinutes  Int      @default(60)
  createdAt     DateTime @default(now())

  users       User[]
  invitations Invitation[]
}

// 유저
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      Role     @default(USER) // String -> Role(Enum)으로 변경
  companyId String
  createdAt DateTime @default(now())

  company         Company         @relation(fields: [companyId], references: [id])
  workLogs        WorkLog[]
  leaveRequests   LeaveRequest[]
  attendanceFixes AttendanceFix[]
}

// 초대 토큰
model Invitation {
  id        String   @id @default(uuid())
  token     String   @unique @default(uuid())
  email     String
  companyId String
  role      Role     @default(USER) // String -> Role(Enum)으로 변경
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

// 출퇴근 기록
model WorkLog {
  id          String    @id @default(uuid())
  userId      String
  companyId   String
  clockIn     DateTime
  clockOut    DateTime?
  workMinutes Int?
  isLate      Boolean   @default(false)
  isOvertime  Boolean   @default(false)
  date        DateTime  @db.Date
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

// 휴가 신청
model LeaveRequest {
  id        String        @id @default(uuid())
  userId    String
  companyId String
  type      LeaveType     @default(ANNUAL) // String -> LeaveType(Enum)으로 변경
  startDate DateTime      @db.Date
  endDate   DateTime      @db.Date
  reason    String
  status    RequestStatus @default(PENDING) // String -> RequestStatus(Enum)으로 변경
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])
}

// 근태 수정 요청
model AttendanceFix {
  id                String        @id @default(uuid())
  userId            String
  companyId         String
  targetDate        DateTime      @db.Date
  reason            String
  requestedClockIn  DateTime?
  requestedClockOut DateTime?
  status            RequestStatus @default(PENDING) // String -> RequestStatus(Enum)으로 변경
  createdAt         DateTime      @default(now())

  user User @relation(fields: [userId], references: [id])
}
