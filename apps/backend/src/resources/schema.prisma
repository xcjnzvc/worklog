generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enum 정의 ---

enum WorkType {
  FIXED // 고정 출퇴근제
  FLEXIBLE // 유연 근무제
  REMOTE // 재택 근무
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  NORMAL // 정상 출퇴근
  LATE // 지각 (출근만 늦음)
  EARLY_LEAVE // 조기 퇴근 (퇴근만 빠름)
  LATE_EARLY // 지각 + 조기 퇴근
  INSUFFICIENT // [유연근무용] 총 시간 미달
  MISSING_OUT // 퇴근 누락 (시스템 강제 종료)
  ABSENT // 결근
}

// --- 모델 정의 ---

model WorkPolicy {
  id        String   @id @default(uuid())
  companyId String
  name      String
  workType  WorkType @default(FIXED)

  workStartTime String @default("09:00")
  workEndTime   String @default("18:00")
  workMinutes   Int    @default(480) // 하루 기준 근무시간(분)

  coreTimeStart String?
  coreTimeEnd   String?

  lunchMinutes   Int    @default(60)
  lunchStartTime String @default("12:00")
  lunchEndTime   String @default("13:00")

  weeklyMustMinutes Int    @default(2400)
  timezone          String @default("Asia/Seoul")

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
  users   User[]
}

model WorkLog {
  id          String           @id @default(uuid())
  userId      String
  companyId   String
  clockIn     DateTime
  clockOut    DateTime?
  workMinutes Int?
  status      AttendanceStatus @default(NORMAL)
  isOvertime  Boolean          @default(false)
  date        DateTime         @db.Date
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, date])
}
